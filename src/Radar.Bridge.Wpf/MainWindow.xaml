<Window x:Class="Yuexin.Radar.Bridge.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:Yuexin.Radar.Bridge.Wpf.Controls"
        mc:Ignorable="d"
        Title="RadarBridge · F10 / F20 控制台"
        Width="1480"
        Height="700"
        MinWidth="1280"
        MinHeight="640"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="170"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0B1725" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="10" Height="10" CornerRadius="5" Background="{StaticResource PrimaryBrush}" Margin="0,0,9,0"/>
                        <TextBlock Text="RADARBRIDGE" FontWeight="Bold" FontSize="19"/>
                    </StackPanel>
                    <TextBlock Text="FaseLase F10 / F20 · 独立点云与 Unity IPC 控制台"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="19,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#12283A" CornerRadius="14" Padding="12,5" Margin="0,0,10,0">
                        <TextBlock Text="{Binding ConnectionStatus}" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#12283A" CornerRadius="14" Padding="12,5">
                        <TextBlock Text="{Binding UnityConnectionText}" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="设备与连接" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="雷达型号" Style="{StaticResource CaptionStyle}"/>
                            <ComboBox ItemsSource="{Binding AvailableModels}" SelectedItem="{Binding SelectedModel}"/>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="型号量程" Style="{StaticResource CaptionStyle}"/>
                                    <TextBlock Text="{Binding ModelMaximumDistanceMeters, StringFormat={}{0:0.#} m}" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="角分辨率" Style="{StaticResource CaptionStyle}"/>
                                    <TextBlock Text="{Binding AngularResolutionDescription}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="{Binding ScanFrequencyDescription}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,8,0,0"/>
                            <Separator/>
                            <TextBlock Text="本机 IPv4 / 网卡" Style="{StaticResource CaptionStyle}"/>
                            <ComboBox IsEditable="True" ItemsSource="{Binding AvailableLocalIps}" SelectedItem="{Binding LocalIp}"/>
                            <Grid Margin="0,9,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="82"/></Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="雷达 IP" Style="{StaticResource CaptionStyle}"/>
                                    <TextBox Text="{Binding RadarIp, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="端口" Style="{StaticResource CaptionStyle}"/>
                                    <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>
                            <CheckBox Content="断线自动重连" IsChecked="{Binding AutoReconnect}" Margin="0,9,0,0"/>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Button Content="连接" Command="{Binding ConnectCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,5,0"/>
                                <Button Grid.Column="1" Content="断开" Command="{Binding DisconnectCommand}" Margin="5,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="数据源与录制" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Button Content="启动模拟" Command="{Binding StartSimulationCommand}" Margin="0,0,5,0"/>
                                <Button Grid.Column="1" Content="停止模拟" Command="{Binding StopSimulationCommand}" Margin="5,0,0,0"/>
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Button Content="开始录制" Click="OnStartRecordingClick" Margin="0,0,5,0"/>
                                <Button Grid.Column="1" Content="停止录制" Click="OnStopRecordingClick" Margin="5,0,0,0"/>
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="72"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <Button Content="回放 .radarrec" Click="OnReplayClick" Margin="0,0,6,0"/>
                                <ComboBox x:Name="ReplaySpeedCombo" Grid.Column="1" SelectedIndex="1">
                                    <ComboBoxItem Content="0.5x" Tag="0.5"/>
                                    <ComboBoxItem Content="1x" Tag="1"/>
                                    <ComboBoxItem Content="2x" Tag="2"/>
                                </ComboBox>
                                <CheckBox x:Name="ReplayLoopCheckBox" Grid.Column="2" Content="循环" Margin="7,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Button Content="暂停" Click="OnPauseReplayClick" Margin="0,0,3,0"/>
                                <Button Grid.Column="1" Content="继续" Click="OnResumeReplayClick" Margin="3,0"/>
                                <Button Grid.Column="2" Content="单圈" Click="OnStepReplayClick" Margin="3,0"/>
                                <Button Grid.Column="3" Content="停止" Click="OnStopReplayClick" Margin="3,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="实时指标" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                <TextBlock Text="扫描频率" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock Grid.Column="1" Text="{Binding ActualScanFrequency}" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Row="1" Text="接收速率" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ReceiveRate}" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Row="2" Text="CRC / 丢弃" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right">
                                    <Run Text="{Binding CrcErrorCount, Mode=OneWay}"/><Run Text=" / "/><Run Text="{Binding DiscardedByteCount, Mode=OneWay}"/>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="52"/><RowDefinition Height="*"/><RowDefinition Height="34"/></Grid.RowDefinitions>
                        <StackPanel Grid.Row="0">
                            <TextBlock Text="区域 1 · 雷达原始数据" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                            <TextBlock Text="未经筛选与坐标变换，仅用于观察传感器回波" Style="{StaticResource CaptionStyle}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" ClipToBounds="True">
                            <controls:RadarPointCloudView x:Name="RawRadarView"
                                                          Snapshot="{Binding LatestSnapshot}"
                                                          MaximumRangeMeters="{Binding VisualizationRangeMeters}"
                                                          ShowRawPoints="True"
                                                          ShowValidPoints="False"
                                                          ShowClusters="False"
                                                          ShowTargets="False"
                                                          ShowFilterOverlay="False"
                                                          ShowBlindZone="False"
                                                          IsRegionEditable="False"/>
                        </Border>
                        <Grid Grid.Row="2" Margin="2,8,2,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="原始点 " Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding RawPointCount}" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock Text="短时余辉仅影响显示" HorizontalAlignment="Right" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="52"/><RowDefinition Height="*"/><RowDefinition Height="34"/></Grid.RowDefinitions>
                        <StackPanel Grid.Row="0">
                            <TextBlock Text="区域 2 · Unity 输出数据" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                            <TextBlock Text="变换与过滤后的有效点；目标由此生成并发送 Unity" Style="{StaticResource CaptionStyle}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" ClipToBounds="True">
                            <controls:RadarPointCloudView x:Name="UnityOutputRadarView"
                                                          Snapshot="{Binding LatestSnapshot}"
                                                          MaximumRangeMeters="{Binding VisualizationRangeMeters}"
                                                          RegionVertices="{Binding RegionVertices}"
                                                          MaskedRegions="{Binding MaskedRegions}"
                                                          ShowRawPoints="False"
                                                          ShowValidPoints="True"
                                                          ShowClusters="False"
                                                          ShowTargets="True"
                                                          ShowFilterOverlay="True"
                                                          ShowBlindZone="False"
                                                          IsRegionEditable="True"
                                                          RegionVertexMoved="OnRegionVertexMoved"/>
                        </Border>
                        <Grid Grid.Row="2" Margin="2,8,2,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="输出点 " Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding ValidPointCount}" Foreground="{StaticResource PrimaryBrush}"/>
                                <TextBlock Text="  目标 " Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding TargetCount}" Foreground="{StaticResource AccentBrush}"/>
                            </StackPanel>
                            <TextBlock Text="拖拽绿色顶点编辑输出区域" HorizontalAlignment="Right" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <ScrollViewer Grid.Column="4" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="区域与安装变换" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,5,0">
                                    <TextBlock Text="最近距离 (m)" Style="{StaticResource CaptionStyle}"/>
                                    <TextBox Text="{Binding MinimumDistanceMeters, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                    <TextBlock Text="最远距离 (m)" Style="{StaticResource CaptionStyle}"/>
                                    <TextBox Text="{Binding MaximumDistanceMeters, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="显示范围（仅缩放，不过滤）" Style="{StaticResource CaptionStyle}" Margin="0,9,0,4"/>
                            <TextBox Text="{Binding VisualizationRangeMeters, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="旋转角度" Style="{StaticResource CaptionStyle}" Margin="0,9,0,4"/>
                            <TextBox Text="{Binding RotationDegrees, UpdateSourceTrigger=PropertyChanged}"/>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,5,0">
                                    <TextBlock Text="X 偏移 (m)" Style="{StaticResource CaptionStyle}"/>
                                    <TextBox Text="{Binding OffsetXMeters, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                    <TextBlock Text="Y 偏移 (m)" Style="{StaticResource CaptionStyle}"/>
                                    <TextBox Text="{Binding OffsetYMeters, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <CheckBox Content="翻转 X" IsChecked="{Binding FlipX}" Margin="0,0,18,0"/>
                                <CheckBox Content="翻转 Y" IsChecked="{Binding FlipY}"/>
                            </StackPanel>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,5,0">
                                    <TextBlock Text="有效角起点" Style="{StaticResource CaptionStyle}"/>
                                    <TextBox Text="{Binding MinimumAngleDegrees, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                    <TextBlock Text="有效角终点" Style="{StaticResource CaptionStyle}"/>
                                    <TextBox Text="{Binding MaximumAngleDegrees, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="边缘死区 L / R / T / B (m)" Style="{StaticResource CaptionStyle}" Margin="0,8,0,4"/>
                            <UniformGrid Columns="4">
                                <TextBox Text="{Binding LeftEdgeDeadZoneMeters, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,3,0"/>
                                <TextBox Text="{Binding RightEdgeDeadZoneMeters, UpdateSourceTrigger=PropertyChanged}" Margin="3,0"/>
                                <TextBox Text="{Binding TopEdgeDeadZoneMeters, UpdateSourceTrigger=PropertyChanged}" Margin="3,0"/>
                                <TextBox Text="{Binding BottomEdgeDeadZoneMeters, UpdateSourceTrigger=PropertyChanged}" Margin="3,0,0,0"/>
                            </UniformGrid>
                            <Button Content="恢复默认有效区域" Command="{Binding ResetRegionCommand}" Margin="0,9,0,0"/>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Button Content="目标处添加屏蔽区" Command="{Binding AddMaskedRegionCommand}" Margin="0,0,5,0"/>
                                <Button Grid.Column="1" Content="删除最后屏蔽区" Command="{Binding DeleteMaskedRegionCommand}" Margin="5,0,0,0"/>
                            </Grid>
                            <TextBlock Text="{Binding MaskedRegionCount, StringFormat=屏蔽区域：{0}}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="聚类与交互" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,5,0">
                                    <TextBlock Text="基础间距" Style="{StaticResource CaptionStyle}"/>
                                    <TextBox Text="{Binding BaseGapMeters, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                    <TextBlock Text="距离系数" Style="{StaticResource CaptionStyle}"/>
                                    <TextBox Text="{Binding DistanceScale, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Pointer 模式" Style="{StaticResource CaptionStyle}" Margin="0,9,0,4"/>
                            <ComboBox ItemsSource="{Binding AvailableInteractionModes}" SelectedItem="{Binding InteractionMode}"/>
                            <TextBlock Text="Dwell 时间 (ms)" Style="{StaticResource CaptionStyle}" Margin="0,9,0,4"/>
                            <TextBox Text="{Binding DwellMilliseconds, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="四点标定" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="顺序：左上 → 右上 → 右下 → 左下" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding CalibrationStep}" Foreground="{StaticResource PrimaryBrush}" Margin="0,7,0,0"/>
                            <TextBlock Text="{Binding CalibrationStatus}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,3,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Button Content="开始" Command="{Binding BeginCalibrationCommand}" Margin="0,0,5,0"/>
                                <Button Grid.Column="1" Content="采集当前目标" Command="{Binding CaptureCalibrationPointCommand}" Margin="5,0,0,0"/>
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Button Content="重做" Command="{Binding UndoCalibrationPointCommand}" Margin="0,0,4,0"/>
                                <Button Grid.Column="1" Content="保存" Command="{Binding SaveCalibrationCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="4,0"/>
                                <Button Grid.Column="2" Content="清除" Command="{Binding ClearCalibrationCommand}" Margin="4,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Unity / IPC" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                <TextBlock Text="状态" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock Grid.Column="1" Text="{Binding UnityConnectionText}" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Row="1" Text="PID" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding UnityStatus.ProcessId}" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Row="2" Text="分辨率" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UnityResolution}" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Row="3" Text="IPC 协议" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="v1" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2" Margin="14,0,14,10" Style="{StaticResource CardStyle}" Padding="12" Background="#091522">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="28"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <TextBlock Text="运行日志（最近 500 条）" Style="{StaticResource SectionTitleStyle}" Margin="0"/>
                    <Button Content="保存配置" Command="{Binding SaveConfigurationCommand}" HorizontalAlignment="Right" Padding="12,3" MinHeight="24"/>
                </Grid>
                <ListBox Grid.Row="1" ItemsSource="{Binding LogEntries}" Background="Transparent" BorderThickness="0"
                         Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>

        <Border Grid.Row="3" Background="#06101A" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="14,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="MODEL " Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
                    <TextBlock Text="{Binding SelectedModel}" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"/>
                    <TextBlock Text="  ·  FRAME " Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
                    <TextBlock Text="{Binding LastFrameSequence}"/>
                </StackPanel>
                <TextBlock Text="Bridge 1.1.5  ·  IPC 1  ·  Windows x64" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
            </Grid>
        </Border>
    </Grid>
</Window>
